<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="451.0" prefWidth="661.0"
            styleClass="root-layout"
            stylesheets="@../styles/AddCategoriesStyles.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.log.ui.AddPropertiesPopupController">

    <!-- CENTER CONTENT -->
    <center>
        <VBox alignment="CENTER"
              spacing="25"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <!-- Title -->
            <Label text="Add Property"
                   styleClass="title" />

            <!-- Input Fields Section -->
            <VBox alignment="CENTER_LEFT"
                  maxWidth="400"
                  spacing="8"
                  styleClass="input-field-container">

                <Label text="Property Name" />
                <TextField fx:id="propertyNameField"
                           maxWidth="Infinity"
                           styleClass="input-field" />

                <Label text="Default Fields" />
                <TextField fx:id="propertyEntriesField"
                           maxWidth="Infinity"
                           styleClass="input-field" />

            </VBox>

        </VBox>
    </center>

    <!-- BOTTOM BUTTONS -->
    <bottom>
        <VBox alignment="CENTER"
              spacing="10"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets bottom="30" top="20" />
            </padding>

            <HBox />

            <Button text="Select/Add Unit"
                    maxWidth="250"
                    onAction="#handleCancel"
                    styleClass="primary-btn" />

            <Button text="Save Attribute"
                    maxWidth="250"
                    onAction="#handleSaveProperty"
                    styleClass="primary-btn" />

            <Button text="Cancel"
                    maxWidth="250"
                    onAction="#handleCancel"
                    styleClass="primary-btn" />

        </VBox>
    </bottom>

</BorderPane>